{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "00. Run Setup Script",
            "type": "process",
            "command": "powershell.exe",
            "args": ["-ExecutionPolicy", "Bypass", "-File", "scripts/setup.ps1"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "01. UV Create Virtual Environment",
            "type": "process",
            "command": "${env:USERPROFILE}\\.local\\bin\\uv.exe",
            "args": ["venv", ".venv"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "02. PS Activate Virtual Environment",
            "type": "process",
            "command": "powershell.exe",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", ".\\.venv\\Scripts\\Activate.ps1"],
            "windows": {
                "command": "powershell.exe",
                "args": ["-ExecutionPolicy", "Bypass", "-Command", ".\\.venv\\Scripts\\Activate.ps1"]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "clear": false,
                "close": false
            },
            "isBackground": false
        },
        {
            "label": "03. UV Install Dependencies",
            "type": "process",
            "command": "${env:USERPROFILE}\\.local\\bin\\uv.exe",
            "args": ["pip", "install", "-r", "pyproject.toml"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "dependsOn": [
                "Update pip"
            ]
        },
        {
            "label": "04. UV cache clean",
            "type": "process",
            "command": "${env:USERPROFILE}\\.local\\bin\\uv.exe",
            "args": ["cache", "clean"],
            "dependsOn": [
                "02. Activate Virtual Environment"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "05. UV sync",
            "type": "process",
            "command": "${env:USERPROFILE}\\.local\\bin\\uv.exe",
            "args": ["sync"],
            "dependsOn": [
                "02. Activate Virtual Environment"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "06. PS Delete Virtual Environment",
            "type": "process",
            "command": "powershell.exe",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "Remove-Item -Recurse -Force .\\.venv"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "07. UV pip list",
            "type": "process",
            "command": "${env:USERPROFILE}\\.local\\bin\\uv.exe",
            "args": ["pip", "list"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "08. Black Format Codebase",
            "type": "process",
            "command": ".\\.venv\\Scripts\\black.exe",
            "args": [
                ".",
                "--exclude",
                ".venv"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "09. Sphinx-build Docs (HTML)",
            "type": "process",
            "command": ".venv\\Scripts\\sphinx-build.exe",
            "args": [
                "-b", "html",   // This specifies the builder (html in this case)
                "docs\\_source",// The source directory containing your reStructuredText files (usually `source`)
                "docs\\_build"  // The directory where the output will be placed (usually `build`)
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "10. Sphinx-build Docs (docx)",
            "type": "process",
            "command": ".venv\\Scripts\\sphinx-build.exe",
            "args": [
                "-b", "docx",   // This specifies the builder (docx in this case)
                "docs\\_source",// The source directory containing your reStructuredText files (usually `source`)
                "docs\\_build"  // The directory where the output will be placed (usually `build`)
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "11. Install R via winget",
            "type": "process",
            "command": "winget",
            "args": [
            "install",
            "--id=RProject.R",
            "-e"
            ],
            "group": {
            "kind": "build",
            "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
            "reveal": "always",
            "focus": true,
            "panel": "shared",
            "clear": false
            }
        },
        {
            "label": "12. Install Anaconda via winget",
            "type": "process",
            "command": "winget",
            "args": [
            "install",
            "--id=Anaconda.Anaconda3",
            "-e"
            ],
            "group": {
            "kind": "build",
            "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
            "reveal": "always",
            "focus": true,
            "panel": "shared",
            "clear": false
            }
        },
        {
            "label": "13. Install Ollama via winget",
            "type": "process",
            "command": "winget",
            "args": [
                "install",
                "--id=Ollama.Ollama",
                "-e"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "14. Pytest - Setup Tests",
            "type": "process",
            "command": ".venv\\Scripts\\pytest.exe",
            "args": [
                "tests/test_setup.py",
                "-v",
                "--tb=short"
            ],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "15. Pytest - All Tests",
            "type": "process",
            "command": ".venv\\Scripts\\pytest.exe",
            "args": [
                "tests/",
                "-v",
                "--tb=short"
            ],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": ["$pytest"],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "16. Render Quarto & Open Index",
            "type": "process",
            "command": "quarto.exe",
            "args": [
                "render",
                "quarto"
            ],
            "options": {
                "env": {
                    "QUARTO_PYTHON": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            },
            "postDebugTask": "Open Quarto Index"
        },
        {
            "label": "Open Quarto Index",
            "type": "process",
            "command": "Start-Process",
            "args": [
                "${workspaceFolder}/quarto/_site/index.html"
            ],
            "windows": {
                "command": "powershell.exe",
                "args": [
                    "-Command",
                    "Start-Process '${workspaceFolder}/_quarto_site/index.html'"
                ]
            },
            "group": {
                "kind": "none",
                "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "clear": false
            }
        }
    ]
}